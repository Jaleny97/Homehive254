APP_NAME="Homehive254"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=homehive254
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=cookie

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@homehive254.com
MAIL_FROM_NAME="Homehive254"

STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

API_ENCRYPTION_KEY=
API_HASH_ALGORITHM=sha256
MAX_LOGIN_ATTEMPTS=5
LOGIN_DECAY_MINUTES=15
SESSION_TIMEOUT=120
FORCE_HTTPS=true
ENABLE_CORS=true
CORS_ALLOWED_ORIGINS=*

JWT_SECRET=
JWT_ALGORITHM=HS256

LOG_CHANNEL=stack
LOG_LEVEL=debug
